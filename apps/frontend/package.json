    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf .next out node_modules/.cache"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@cerebrum/eslint-config": "workspace:*",
    "@cerebrum/tsconfig": "workspace:*",
    "@cerebrum/shared-types": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.13.0",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
