{
  "name": "@cerebrum/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Cerebrum frontend — Thin Frontend Layer (Next.js/React/TypeScript). See docs/architecture/specification/85_Frontend_Architecture.md.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
