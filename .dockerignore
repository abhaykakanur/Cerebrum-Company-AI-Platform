# ==============================================================================
# Cerebrum — Docker build-context exclusions
#
# Keeps the build context sent to the Docker daemon small and free of
# secrets/local state. apps/backend/Dockerfile only ever COPYs specific
# paths (never `COPY . .`), so this file is a build-speed/hygiene
# safeguard, not the sole mechanism preventing e.g. a local `.env` from
# reaching an image layer.
# ==============================================================================

# Version control / editor / OS
.git/
.github/
.vscode/
.devcontainer/
.idea/
.DS_Store

# Environment / secrets — never baked into an image
.env
.env.*
!.env.example

# Python
**/__pycache__/
**/*.py[cod]
**/.venv/
**/.mypy_cache/
**/.ruff_cache/
**/.pytest_cache/
**/*.egg-info/
**/htmlcov/
**/.coverage

# Node / frontend workspace — apps/backend/Dockerfile never COPYs these
# paths, and apps/frontend/Dockerfile only COPYs specific package.json
# files plus apps/frontend/ and packages/ source directly (not via
# `COPY . .`), so excluding node_modules/build-output here is a
# build-speed/hygiene safeguard for both images, not a path either
# Dockerfile depends on being absent.
node_modules/
**/node_modules/
apps/frontend/.next/
apps/frontend/out/
packages/*/dist/

# Docs, tests, and non-build-context repo scaffolding
docs/
apps/backend/tests/
apps/frontend/tests/
scripts/
examples/
assets/
tools/
infrastructure/docker/

# Build output
dist/
build/
