# EditorConfig — https://editorconfig.org
# Keeps formatting consistent across editors ahead of Black/Prettier enforcement.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 88

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{bat,ps1}]
end_of_line = crlf
