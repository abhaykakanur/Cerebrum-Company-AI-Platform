{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Backend (pytest — current file)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Python: Backend (all unit tests)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["apps/backend/tests", "-m", "unit", "-v"],
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Next.js: Frontend (dev server)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm --filter @cerebrum/frontend dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Next.js: Frontend (Chrome debug)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/frontend"
    }
  ]
}
