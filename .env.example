# ==============================================================================
# Cerebrum — Environment Variable Template
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# NEVER commit a real `.env` file. NEVER put a real secret value in this file.
# This template documents which variables exist and their shape; see
# docs/architecture/specification/37_Configuration_Strategy.md for the full
# configuration architecture (env vars vs. config files vs. secrets vs.
# feature flags vs. runtime configuration) and
# docs/architecture/specification/75_Security_Architecture.md for why
# secrets specifically are never handled via this file in staging/production.
# ==============================================================================

# --- Environment ---------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=info
LOG_FORMAT=json

# --- Backend (FastAPI) ------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- Transport security ------------------------------------------------------
# '*' is a development-only default — SECURITY_TRUSTED_HOSTS cannot be '*'
# and SECURITY_CORS_ALLOWED_ORIGINS cannot contain '*' once ENVIRONMENT is
# staging/production (enforced at startup — see cerebrum.config.settings).
SECURITY_TRUSTED_HOSTS=*
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Infrastructure connection policy -----------------------------------------
# Retry/backoff/timeout every infrastructure client manager
# (cerebrum.infrastructure.*.manager) uses when connecting at startup — see
# docs/architecture/infrastructure/connection-lifecycle.md.
INFRA_CONNECT_RETRIES=3
INFRA_CONNECT_RETRY_BACKOFF_SECONDS=0.5
INFRA_CONNECT_TIMEOUT_SECONDS=5.0

# --- Frontend (Next.js) ------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# --- PostgreSQL --------------------------------------------------------------
# Authoritative relational datastore — docs/architecture/specification/42_Database_Responsibilities.md
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cerebrum
POSTGRES_USER=cerebrum
POSTGRES_PASSWORD=changeme-local-only

# --- Neo4j ---------------------------------------------------------------
# Authoritative relationship datastore
NEO4J_HOST=localhost
NEO4J_HTTP_PORT=7474
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-local-only

# --- Qdrant ----------------------------------------------------------------
# Authoritative vector datastore
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Redis -----------------------------------------------------------------
# Cache, sessions, rate limits, Celery broker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme-local-only

# --- MinIO (S3-API-compatible object storage) --------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=changeme-local-only
MINIO_SECRET_KEY=changeme-local-only
MINIO_BUCKET=cerebrum-documents
MINIO_SECURE=false

# --- OpenSearch --------------------------------------------------------------
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_PERF_PORT=9600

# --- Background runtime (currently unimplemented — see cerebrum.workers) -----
WORKER_CONCURRENCY=4
WORKER_ENABLED=false

# --- Observability toggles (currently no-op — see cerebrum.core.observability)
MONITORING_METRICS_ENABLED=false
MONITORING_TRACING_ENABLED=false

# --- Secrets (local development ONLY — see Security Architecture) ------------
# In staging/production, secrets are retrieved via the Security Domain's
# GetSecret port from a dedicated secrets backend, never from environment
# variables populated by this file. Local-only placeholder values below.
JWT_SIGNING_SECRET=changeme-local-only-do-not-use-in-production

# --- AI Model Providers (local development placeholders) ---------------------
# See docs/architecture/specification/60_AI_Model_Abstraction.md.
# Leave blank locally if not exercising AI features yet — no default
# provider is committed to by this specification (Open Question 72).
LLM_PROVIDER=
LLM_API_KEY=
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=

# --- Feature Flags (local development overrides) ------------------------------
# See docs/architecture/specification/37_Configuration_Strategy.md.
FEATURE_FLAGS_OVERRIDE_FILE=config/development/feature_flags.local.yaml
