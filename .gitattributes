# ==============================================================================
# Cerebrum — .gitattributes
# Normalizes line endings and marks generated/binary files to keep diffs clean.
# ==============================================================================

# Default: normalize to LF in the repository, checkout using the platform's
# native line ending, unless overridden below.
* text=auto eol=lf

# --- Explicit text types --------------------------------------------------
*.py       text diff=python
*.ts       text
*.tsx      text
*.js       text
*.jsx      text
*.json     text
*.md       text diff=markdown
*.yml      text
*.yaml     text
*.toml     text
*.cfg      text
*.ini      text
*.sh       text eol=lf
*.env.example text

# Windows-specific scripts keep CRLF
*.bat      text eol=crlf
*.ps1      text eol=crlf

# --- Binary types (never diffed, never line-ending-converted) -----------------
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.eot      binary

# --- Lockfiles: preserved verbatim, excluded from language-stat diffs ------------
pnpm-lock.yaml -diff linguist-generated=true
uv.lock        -diff linguist-generated=true

# --- Generated / vendored directories excluded from GitHub language stats -------
docs/architecture/specification/* linguist-documentation
